    <bpmn:scriptTask id="Task_2" name="Agent 2: Promotion Analysis" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"vars":{"type":"object"},"metadata":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"vars":"=vars","metadata":"=metadata"}]]></uipath:input>
          <uipath:output name="scriptResponse" type="jsonSchema" source="=result.response" var="scriptResponse" />
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error2" />
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:script><![CDATA[const csvData = vars.csvRawData;
const lines = String(csvData).trim().split('\n');
const headers = lines[0].split(',');
const promoIdx = headers.indexOf('promo_flag');
const unitsIdx = headers.indexOf('units_sold');
const catIdx = headers.indexOf('category');
const chanIdx = headers.indexOf('channel');
const countryIdx = headers.indexOf('country');
let promoUnits = [], noPromoUnits = [];
let categoryData = {}, channelData = {}, countryData = {};
for (let i = 1; i < lines.length; i++) {
  const cols = lines[i].split(',');
  const units = parseFloat(cols[unitsIdx]);
  const isPromo = cols[promoIdx] === '1';
  const cat = cols[catIdx];
  const chan = cols[chanIdx];
  const country = cols[countryIdx];
  if (isPromo) promoUnits.push(units);
  else noPromoUnits.push(units);
  if (!categoryData[cat]) categoryData[cat] = { promo: [], noPromo: [] };
  if (isPromo) categoryData[cat].promo.push(units); else categoryData[cat].noPromo.push(units);
  if (!channelData[chan]) channelData[chan] = { promo: [], noPromo: [] };
  if (isPromo) channelData[chan].promo.push(units); else channelData[chan].noPromo.push(units);
  if (!countryData[country]) countryData[country] = { promo: [], noPromo: [] };
  if (isPromo) countryData[country].promo.push(units); else countryData[country].noPromo.push(units);
}
const avg = arr => arr.length ? arr.reduce((a,b) => a+b,0) / arr.length : 0;
const uplift = (p, n) => n ? ((avg(p) - avg(n)) / avg(n) * 100).toFixed(1) : "0";
return {
  overall_uplift: uplift(promoUnits, noPromoUnits),
  cat_personal_care: uplift(categoryData["Personal Care"] ? categoryData["Personal Care"].promo : [], categoryData["Personal Care"] ? categoryData["Personal Care"].noPromo : []),
  cat_dairy: uplift(categoryData["Dairy"] ? categoryData["Dairy"].promo : [], categoryData["Dairy"] ? categoryData["Dairy"].noPromo : []),
  cat_home_care: uplift(categoryData["Home Care"] ? categoryData["Home Care"].promo : [], categoryData["Home Care"] ? categoryData["Home Care"].noPromo : []),
  cat_snacks: uplift(categoryData["Snacks"] ? categoryData["Snacks"].promo : [], categoryData["Snacks"] ? categoryData["Snacks"].noPromo : []),
  cat_beverages: uplift(categoryData["Beverages"] ? categoryData["Beverages"].promo : [], categoryData["Beverages"] ? categoryData["Beverages"].noPromo : []),
  chan_hypermarket: uplift(channelData["Hypermarket"] ? channelData["Hypermarket"].promo : [], channelData["Hypermarket"] ? channelData["Hypermarket"].noPromo : []),
  chan_ecommerce: uplift(channelData["E-commerce"] ? channelData["E-commerce"].promo : [], channelData["E-commerce"] ? channelData["E-commerce"].noPromo : []),
  chan_supermarket: uplift(channelData["Supermarket"] ? channelData["Supermarket"].promo : [], channelData["Supermarket"] ? channelData["Supermarket"].noPromo : []),
  chan_convenience: uplift(channelData["Convenience"] ? channelData["Convenience"].promo : [], channelData["Convenience"] ? channelData["Convenience"].noPromo : [])
};

]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Task_3" name="Agent 3: Trend Detection" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"vars":{"type":"object"},"metadata":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"vars":"=vars","metadata":"=metadata"}]]></uipath:input>
          <uipath:output name="scriptResponse" type="jsonSchema" source="=result.response" var="scriptResponse2" />
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error3" />
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:script><![CDATA[const csvData = vars.csvRawData;
const lines = String(csvData).trim().split('\n');
const headers = lines[0].split(',');
const promoIdx = headers.indexOf('promo_flag');
const unitsIdx = headers.indexOf('units_sold');
const discIdx = headers.indexOf('discount_pct');
const weekendIdx = headers.indexOf('is_weekend');
const holidayIdx = headers.indexOf('is_holiday');
let bogo = [], flat = [], weekend = [], weekday = [], holiday = [], nonHoliday = [];
for (let i = 1; i < lines.length; i++) {
  const cols = lines[i].split(',');
  if (cols[promoIdx] !== '1') continue;
  const units = parseFloat(cols[unitsIdx]);
  const disc = parseFloat(cols[discIdx]);
  const isWeekend = cols[weekendIdx] === '1';
  const isHoliday = cols[holidayIdx] === '1';
  if (disc >= 0.25) bogo.push(units);
  else flat.push(units);
  if (isWeekend) weekend.push(units); else weekday.push(units);
  if (isHoliday) holiday.push(units); else nonHoliday.push(units);
}
const avg = arr => arr.length ? arr.reduce((a,b) => a+b,0) / arr.length : 0;
return {
  bogo_avg_units: avg(bogo).toFixed(2),
  flat_avg_units: avg(flat).toFixed(2),
  weekend_avg_units: avg(weekend).toFixed(2),
  weekday_avg_units: avg(weekday).toFixed(2),
  holiday_avg_units: avg(holiday).toFixed(2),
  non_holiday_avg_units: avg(nonHoliday).toFixed(2)
};

]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:sendTask id="Task_4" name="Agent 4: Generate AI Insights">
      <bpmn:extensionElements>
