            <uipath:input name="metadata" type="json"><![CDATA[{"designTimeMetadata":{"connectorLogoUrl":"https://cloud.uipath.com/elements_/scaleunit_/58cb4f17-4581-4130-a2ae-52448b37dc03/v3/element/elements/uipath-anthropic-claude/image","activityDesignerVersion":"2","activityDisplayName":"Generate Message","activityDescription":"Generate message responses using Anthropic Claude based on a given prompt.","activityHelpUrlTemplate":"https://docs.uipath.com/{0}/activities/other/latest/integration-service/uipath-anthropic-claude-Generate-Message","activityConfig":{"isCurated":true,"operation":null}},"metadataState":{"jsonSchema":{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"model":{"title":"Model","type":"string","description":"The Claude model to use for generating the message"},"text":{"title":"Generated text","type":"string","description":"The text generated by Claude"},"id":{"title":"Message ID","type":"string","description":"The unique message identifier"},"stopReason":{"title":"Stop reason","type":"string","description":"The reason the model stopped generating (end_turn, max_tokens, stop_sequence)"},"inputTokens":{"title":"Input tokens","type":"integer","description":"The number of input tokens consumed"},"outputTokens":{"title":"Output tokens","type":"integer","description":"The number of output tokens generated"}},"definitions":{}}},"telemetryData":{"operationType":"Create","objectName":"messages","objectDisplayName":"Message object","connectorKey":"uipath-anthropic-claude","connectorName":"Anthropic Claude","primaryKeyName":""},"inputMetadata":{},"errorState":{"hasError":false},"bindings":[]}]]></uipath:input>
          </uipath:context>
          <uipath:input name="body" type="json" target="body"><![CDATA[{"model":"claude-sonnet-4-6","maxTokens":1024,"systemPrompt":"You are a helpful assistant.","temperature":1,"topK":1,"prompt":"=js:\"You are an FMCG analyst. Overall promo uplift is \" + vars.scriptResponse.overall_uplift + \"%. Flat discount averages \" + vars.scriptResponse2.flat_avg_units + \" units vs BOGO at \" + vars.scriptResponse2.bogo_avg_units + \" units. Category breakdown: \" + vars.scriptResponse.category_uplift + \". Generate: 1) 2-sentence executive summary. 2) Two actionable recommendations.\""}]]></uipath:input>
          <uipath:output name="text" type="string" source="=response.text" var="text" />
          <uipath:output name="response" type="jsonSchema" source="=response" var="response3" />
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error4" />
        </uipath:activity>
      </bpmn:extensionElements>
